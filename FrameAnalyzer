def calculate_equivalent_nodal_forces(self, elem_id, load_data):
        """
        PURPOSE: Calculates Fixed End Forces (FEF) for member loads and 
                 converts them to equivalent nodal forces in global coordinates.
        INPUTS: 
            elem_id (int): ID of the loaded member.
            load_data (dict): Type, direction, and magnitude of the load.
        OUTPUTS: fef_global (list of 6 terms)
        """
        # 1. Eleman geometrisini al
        _, L, cos, sin = self.get_element_geometry(elem_id)
        
        # 2. Local FEF vektörünü başlat [fx1, fy1, mz1, fx2, fy2, mz2]
        fef_local = [0.0] * 6
        
        load_val = load_data['value']
        
        # SENARYO A: Vertical Distributed Load (UDL - Kiriş üzerinde yayılı yük)
        if load_data['type'] == "UDL_Vertical":
            # Standart wL/2 ve wL^2/12 formülleri
            fef_local[1] = load_val * L / 2.0      # Shear 1
            fef_local[2] = load_val * L**2 / 12.0  # Moment 1
            fef_local[4] = load_val * L / 2.0      # Shear 2
            fef_local[5] = -load_val * L**2 / 12.0 # Moment 2

        # SENARYO B: Concentrated Member Load (Eleman ortasında tekil yük)
        elif load_data['type'] == "Point_Load":
            a = load_data.get('distance', L/2) # Yükün konumu (default orta nokta)
            b = L - a
            # P*b/L, P*a*b^2/L^2 gibi standart statik formülleri
            fef_local[1] = (load_val * b**2 * (3*a + b)) / L**3
            fef_local[2] = (load_val * a * b**2) / L**2
            # ... diğer uç kuvvetleri de buraya eklenir ...

        # 3. Global Koordinat Sistemine Dönüşüm (R_transpose * fef_local)
        fef_global = self.transform_vector_to_global(fef_local, cos, sin)
        
        return fef_global
