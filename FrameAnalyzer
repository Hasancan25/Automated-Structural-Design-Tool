import math
from matrix_lib import BandedSymmetricMatrix
from solver import Solver

class FrameAnalyzer:
    """
    PURPOSE: Executes the 13-step Matrix Displacement Method for 2D Frames.
    It handles dynamic geometries where node and member counts are variable.
    """
    def __init__(self, xy, m_props, connectivity, supports, loads, half_bw):
        """
        INPUTS: 
            xy (list): Nodal coordinates.
            m_props (list): Material properties [A, I, E].
            connectivity (list): Element mapping [Start, End, MatID].
            supports (list): Boundary conditions.
            loads (list): Applied nodal forces.
            half_bw (int): Calculated optimal bandwidth.
        """
        self.xy = xy
        self.m_props = m_props
        self.connectivity = connectivity
        self.supports = supports
        self.loads = loads
        self.half_bw = half_bw
        
        self.num_node = len(xy)
        self.num_elem = len(connectivity)
        self.e_array = [] # DOF mapping
        self.num_eq = 0   # Total active equations

    def label_active_dof(self):
        """
        PURPOSE: Steps 1-8: Automatically assigns global equation numbers.
        OUTPUTS: self.num_eq (int), self.e_array (list)
        """
        self.e_array = [[0, 0, 0] for _ in range(self.num_node)]
        count = 0
        for i in range(self.num_node):
            for j in range(3): # 3 DOFs per node
                if self.supports[i][j] == 0: # If free
                    count += 1
                    self.e_array[i][j] = count
        self.num_eq = count
        return self.num_eq

    def get_element_stiffness_global(self, elem_id):
        """
        PURPOSE: Steps 9-10: Computes kglobal = [R]^T * [k_local] * [R].
        INPUTS: elem_id (int)
        OUTPUTS: k_global (6x6 matrix as list of lists)
        """
        # 1. Get Geometry
        start_node, end_node, mat_id = self.connectivity[elem_id]
        x1, y1 = self.xy[start_node - 1]
        x2, y2 = self.xy[end_node - 1]
        L = math.sqrt((x2 - x1)**2 + (y2 - y1)**2)
        cos, sin = (x2 - x1) / L, (y2 - y1) / L
        
        # 2. Get Material Properties
        A, I, E = self.m_props[mat_id - 1]
        
